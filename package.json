{
	"name": "ctrl-s",
	"displayName": "CTRL + S",
	"description": "The extension that keeps track of how many times you press ctrl + s, to really make sure you saved that file.",
	"version": "1.1.0",
	"author": "coalaura",
	"publisher": "coalaura",
	"icon": "logo.png",
	"galleryBanner": {
		"color": "#E1DDCA",
		"theme": "light"
	},
	"license": "SEE LICENSE IN LICENSE",
	"keywords": [
		"saving",
		"ctrl",
		"statistics",
		"stats",
		"count",
		"save",
		"counter"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/coalaura/ctrl-s"
	},
	"engines": {
		"vscode": "^1.77.0"
	},
	"categories": [
		"Snippets",
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"configuration": {
			"title": "CTRL-S",
			"properties": {
				"ctrl-s.fullNumber": {
					"type": "boolean",
					"default": false,
					"markdownDescription": "Always show the full number instead of its short form (1,234,567 instead of 1.2 million)."
				}
			}
		},
		"commands": [
			{
				"command": "ctrl-s.showStatistics",
				"title": "Show CTRL + S Statistics"
			},
			{
				"command": "ctrl-s.resetStatistics",
				"title": "Reset CTRL + S Statistics"
			}
		]
	},
	"scripts": {
		"lint": "eslint .",
		"package": "bun run build && vsce package",
		"build": "bun esbuild.config.js",
		"watch": "bun esbuild.config.js --watch"
	},
	"devDependencies": {
		"@types/node": "16.x",
		"@types/vscode": "^1.77.0",
		"esbuild": "^0.19.5",
		"esbuild-copy-static-files": "^0.1.0",
		"eslint": "^8.36.0",
		"typescript": "^4.9.5"
	}
}